{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "Registro de una persona asignada a una sección",
      "type": "object",
      "properties": {
        "personName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "ineFrontUrl": { "type": "string", "description": "URL de la foto frontal de la INE" },
        "ineBackUrl": { "type": "string", "description": "URL de la foto reverso de la INE" },
        "sectionId": { "type": "string" },
        "sectionName": { "type": "string" },
        "casilla": { "type": "string", "description": "Casilla seleccionada para este registro" },
        "responsibleId": { "type": "string" },
        "responsibleEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["personName", "phoneNumber", "ineFrontUrl", "ineBackUrl", "sectionId", "casilla", "responsibleId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Perfil de usuario del sistema",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "assignedSections": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "IDs de las secciones asignadas a este usuario"
        }
      },
      "required": ["email"]
    },
    "Section": {
      "title": "Section",
      "description": "Definición dinámica de una sección",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "casillas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lista de casillas disponibles para esta sección"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Configuración global de la interfaz",
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "evidenceEnabled": { "type": "boolean" },
        "evidenceStartDate": { "type": "string" },
        "evidenceEndDate": { "type": "string" }
      }
    },
    "Evidence": {
      "title": "Evidence",
      "description": "Capturas de pantalla subidas por los usuarios",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "periodStart": { "type": "string", "description": "Fecha de inicio del periodo en que se subió" },
        "periodEnd": { "type": "string", "description": "Fecha de fin del periodo en que se subió" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "feedback": { "type": "string" }
      },
      "required": ["userId", "imageUrl", "timestamp", "periodStart", "periodEnd", "status"]
    }
  },
  "firestore": {
    "/registrations/{registrationId}": { "schema": "Registration", "description": "Colección de registros de personal" },
    "/users/{userId}": { "schema": "User", "description": "Colección de perfiles de usuario" },
    "/sections/{sectionId}": { "schema": "Section", "description": "Colección dinámica de secciones" },
    "/settings/global": { "schema": "Settings", "description": "Configuración de la UI" },
    "/evidence/{evidenceId}": { "schema": "Evidence", "description": "Evidencias fotográficas" }
  }
}
